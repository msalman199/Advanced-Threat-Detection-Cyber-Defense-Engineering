Task 2: Configure Zeek for TLS Monitoring
Step 2.1: Install Zeek Network Monitor
# Install Zeek dependencies
sudo apt install -y cmake make gcc g++ flex bison libpcap-dev \
    libssl-dev python3-dev swig zlib1g-dev

# Download Zeek
cd ~/tls-anomaly-lab
wget https://download.zeek.org/zeek-4.2.1.tar.gz
tar -xzf zeek-4.2.1.tar.gz
cd zeek-4.2.1

# Configure and install
./configure --prefix=/opt/zeek
make -j$(nproc)
sudo make install

# Add to PATH
echo 'export PATH=/opt/zeek/bin:$PATH' >> ~/.bashrc
source ~/.bashrc

# Verify installation
zeek --version
