Task 3: Validate and Optimize Signatures
Step 1: Test Individual Signatures
Create a simple test script ~/test_single_rule.sh:

#!/bin/bash

# Test specific signature by generating targeted traffic
# Usage: ./test_single_rule.sh <test_type>

TEST_TYPE=$1

case $TEST_TYPE in
    sql)
        curl "http://127.0.0.1:8080/search?id=' OR 1=1--"
        ;;
    xss)
        curl "http://127.0.0.1:8080/comment?msg=<script>alert('XSS')</script>"
        ;;
    scan)
        nmap -sS 127.0.0.1 -p 1-100
        ;;
    *)
        echo "Usage: $0 {sql|xss|scan}"
        ;;
esac
