Task 1: Install and Configure Zeek
Step 1.1: Install Zeek from Package Repository
# Add Zeek repository
echo 'deb http://download.opensuse.org/repositories/security:/zeek/xUbuntu_20.04/ /' | sudo tee /etc/apt/sources.list.d/security:zeek.list
curl -fsSL https://download.opensuse.org/repositories/security:zeek/xUbuntu_20.04/Release.key | gpg --dearmor | sudo tee /etc/apt/trusted.gpg.d/security_zeek.gpg > /dev/null

# Install Zeek
sudo apt update
sudo apt install -y zeek

# Add Zeek to PATH
echo 'export PATH=/opt/zeek/bin:$PATH' >> ~/.bashrc
source ~/.bashrc
Step 1.2: Configure Network Interface
# Identify your network interface
ip addr show

# Configure Zeek node (replace eth0 with your interface)
sudo tee /opt/zeek/etc/node.cfg << 'EOF'
[zeek]
type=standalone
host=localhost
interface=eth0
EOF

# Configure monitored networks
sudo tee /opt/zeek/etc/networks.cfg << 'EOF'
10.0.0.0/8          Private IP space
172.16.0.0/12       Private IP space
192.168.0.0/16      Private IP space
EOF
