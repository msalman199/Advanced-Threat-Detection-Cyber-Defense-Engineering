Task 1: Install and Configure Cribl Stream
Step 1.1: Install Cribl Stream
Download and install Cribl Stream on your Linux machine:

# Create working directory
mkdir -p ~/cribl-lab && cd ~/cribl-lab

# Download Cribl Stream
wget https://cdn.cribl.io/dl/4.5.3/cribl-4.5.3-e3c67b52-linux-x64.tgz

# Extract and move to /opt
tar -xzf cribl-4.5.3-e3c67b52-linux-x64.tgz
sudo mv cribl /opt/

# Create cribl user and set permissions
sudo useradd -r -s /bin/false cribl
sudo chown -R cribl:cribl /opt/cribl

# Start Cribl
sudo -u cribl /opt/cribl/bin/cribl start

# Verify Cribl is running
curl http://localhost:9000/api/v1/system/info
Step 1.2: Access Cribl Web Interface
# Get your machine's external IP
echo "Access Cribl at: http://$(curl -s ifconfig.me):9000"

# Default credentials: admin/admin (change on first login)
